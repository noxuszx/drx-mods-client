# Mods should be managed by Packwiz, not committed as jar files.
minecraft/mods/*.jar
minecraft/mods/*.disabled
minecraft/mods/.index/
minecraft/mods_disabled/

# Generated by packwiz-installer-bootstrap at launch time.
minecraft/packwiz-installer.jar
minecraft/packwiz-installer-bootstrap.jar
minecraft/packwiz.json

